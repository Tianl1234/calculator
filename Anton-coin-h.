const coins = 42;

const sourceId = localStorage
    .getItem('sourceId')
    ?.replace(/"/g, '');

const deviceLogId = localStorage
    .getItem('deviceLogId')
    ?.replace(/"/g, '');

const users = JSON.parse(localStorage.getItem('users') || '[]');

users.forEach(user => {
    fetch('https://logger-lb-5.anton.app/events', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
            events: [
                {
                    event: 'adjustCoins',
                    value: coins,
                    src: sourceId,
                    created: new Date().toISOString()
                }
            ],
            log: user.l,
            credentials: {
                authToken: user.t,
                deviceLogId: deviceLogId
            }
        })
    })
        .then(response => response)
        .catch(error => error)
        .then(() => {
            window.location.reload();
        });
});
